# Get your key from https://console.anthropic.com/
# Required for: URL job importer (Claude parsing), company research, brand color lookup
VITE_ANTHROPIC_API_KEY=sk-ant-...
# Also accepted as:
# ANTHROPIC_API_KEY=sk-ant-...

# --- Upstash Redis (required for Vercel deployment) ---
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# --- Optional ---

# API server URL. Only needed if API is on a different origin from the frontend.
# When using "npm run dev", the Vite dev server proxies /api → localhost:3001.
# On Vercel, the API lives at the same origin (serverless functions), so leave unset.
# VITE_API_URL=http://localhost:3001

# Resend (for email key recovery)
# RESEND_API_KEY=re_...
# RESEND_FROM=Scout <noreply@yourdomain.com>

# App origin for recovery email links (auto-detected on Vercel)
# APP_ORIGIN=https://your-app.vercel.app

# Allowed origins for API (Origin/Referer check). Comma-separated. If unset, defaults include scoutboard.xyz and localhost.
# ALLOWED_ORIGINS=https://scoutboard.xyz,https://your-app.vercel.app
