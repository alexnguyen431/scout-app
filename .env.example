# Get your key from https://console.anthropic.com/
# Required for: URL job importer (Claude parsing), company research, paste extraction
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional: API server URL. Only needed if you're NOT using the Vite dev server (e.g. production build or static host).
# When using "npm run dev", the app proxies /api to the server; leave this unset.
# VITE_API_URL=http://localhost:3001

# Optional: override the job proxy (default: https://scout-api.vercel.app/api/job)
# VITE_JOB_PROXY_BASE=https://your-project.vercel.app/api/job

# Brand colors: server uses Claude (same key as above) and caches in data/brand_colors.json so each company is only looked up once.
# Company research (Add Company / auto-research): server caches in data/company_research.json so each company is only looked up once.
